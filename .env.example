# ============================================
# POLYPULSE BOT v2.0 - CONFIGURATION TEMPLATE
# ============================================
# Copy this to .env and fill in your values
# ============================================

# ==========================================
# WALLET SECURITY (Required for trading)
# ==========================================
PRIVATE_KEY=0x...              # Your Polygon wallet private key (0x + 64 chars)
WALLET_ADDRESS=0x...           # Your wallet address (0x + 40 chars)

# ==========================================
# POLYMARKET L2 API (Required for trading)
# ==========================================
POLY_API_KEY=                  # Generated from your private key
POLY_API_SECRET=               # Generated API secret
POLY_API_PASSPHRASE=           # Generated API passphrase

# ==========================================
# NETWORK CONFIGURATION
# ==========================================
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137                   # Polygon mainnet

# ==========================================
# AI INTELLIGENCE ENGINE
# ==========================================
# Provider options: standard, gemini, openai, anthropic, groq, openrouter, nvidia, huggingface, xai, ollama, lmstudio
ANALYZER_TYPE=standard

# Minimum confidence (0-1) required for AI to approve trade
AI_CONFIDENCE_THRESHOLD=0.65

# ==========================================
# AI PROVIDER API KEYS (Configure your chosen provider)
# ==========================================
# Google Gemini (Vertex AI)
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=

# OpenAI (GPT-4o, o1, etc.)
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Opus)
ANTHROPIC_API_KEY=

# Groq (Ultra-fast Llama inference)
GROQ_API_KEY=

# OpenRouter (50+ models)
OPENROUTER_API_KEY=

# NVIDIA (Nemotron models)
NVIDIA_API_KEY=

# HuggingFace (Open-source LLMs)
HUGGINGFACE_API_KEY=

# xAI (Grok - Elon's AI)
XAI_API_KEY=

# ==========================================
# AI MODEL SELECTION
# ==========================================
OPENAI_MODEL=gpt-4o                    # Options: gpt-4o, gpt-4o-mini, o1-preview, o1-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # Options: claude-3-5-sonnet, claude-3-opus
GROQ_MODEL=llama-3.1-70b-versatile     # Options: llama-3.1-70b, mixtral-8x7b, llama-3.1-8b
OPENROUTER_MODEL=meta-llama/llama-3.1-405b-instruct
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
XAI_MODEL=grok-beta
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-70B-Instruct
LOCAL_MODEL=llama3.1:8b                # For Ollama/LM Studio

# ==========================================
# TRADING PARAMETERS
# ==========================================
# Minimum profit threshold (0.005 = 0.5%)
MIN_PROFIT_THRESHOLD=0.005

# Maximum position size per market in USD
MAX_POSITION_SIZE=100

# Minimum liquidity required in USD
MIN_LIQUIDITY_USD=5000

# Seconds between market scans
POLL_INTERVAL_SECONDS=2

# Maximum days until market resolution to consider
MAX_DAYS_UNTIL_RESOLUTION=7

# Minimum 24h volume to consider market
MIN_VOLUME_24H=1000

# ==========================================
# RISK MANAGEMENT
# ==========================================
# Risk per trade as % of account
RISK_PER_TRADE_PCT=0.8

# Stop loss percentage from entry
STOP_LOSS_PCT=5.0

# Maximum position as % of account
POSITION_CAP_PCT=25.0

# Take profit target (% to 1.00)
TAKE_PROFIT_PCT_TO_ONE=55.0

# Consecutive losses before pause
CONSECUTIVE_LOSSES_PAUSE=5
CONSECUTIVE_LOSS_PAUSE_MINUTES=30

# Session drawdown limits
SESSION_DRAWDOWN_PCT=4.0
SESSION_PAUSE_MINUTES=60

# Daily drawdown limit
DAILY_DRAWDOWN_PCT=8.0

# Monthly drawdown (halts bot)
MONTHLY_DRAWDOWN_PCT=20.0

# ==========================================
# STRATEGY SETTINGS
# ==========================================
# Enable flash crash detection
ENABLE_FLASH_CRASH=true

# Enable mean reversion strategy
ENABLE_MEAN_REVERSION=true

# Enable momentum breakout strategy
ENABLE_MOMENTUM=true

# Enable spread trading strategy
ENABLE_SPREAD=true

# AI sentiment filtering for directional trades
USE_SENTIMENT_FILTER=true

# ==========================================
# TECHNICAL INDICATORS
# ==========================================
# Volatility filter - skip if 1-min std > this
VOLATILITY_SKIP_1MIN_STD=0.028

# Mean reversion z-score filter
MAX_ZSCORE_3MIN=2.5

# RSI overbought filter (skip if RSI > this)
MAX_RSI_OVERBOUGHT=80

# Minimum seconds until resolution to enter
MIN_SECONDS_UNTIL_RESOLUTION=90

# ==========================================
# DASHBOARD CONFIGURATION
# ==========================================
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# ==========================================
# MODE
# ==========================================
# Dry run = simulate trades, no real money
DRY_RUN=true

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR

# ==========================================
# PROXY CONFIGURATION (Optional - geo bypass)
# ==========================================
SOCKS5_PROXY_HOST=
SOCKS5_PROXY_PORT=1080
SOCKS5_PROXY_USER=
SOCKS5_PROXY_PASS=

# ==========================================
# ALERTS (Optional)
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEMED_CHAT_ID=
SLACK_WEBHOOK_URL=
